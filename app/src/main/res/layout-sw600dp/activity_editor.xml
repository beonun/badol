<?xml version="1.0" encoding="utf-8"?>
<!--
    Portrait Editor 레이아웃 (태블릿 sw >= 600dp)
    - 바둑판 영역 weight=65: 태블릿 세로에서 가로폭 기준 정사각형이 충분히 들어가도록
    - 하단 컨트롤 영역 weight=35: 편집 버튼 + 기보 목록 표시에 충분한 공간
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="100"
    android:background="@color/board_color">

    <!-- 툴바 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/btn_scan"
            app:titleTextColor="#FFFFFF"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 바둑판 영역 (weight=70) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="70"
        android:orientation="vertical"
        android:background="@color/board_color">

        <!-- 바둑판 상단 여백 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/board_margin_top"
            android:background="@color/board_color" />

        <!-- 바둑판 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:background="@color/board_color">

            <com.badol.studio.BoardView
                android:id="@+id/boardView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- 바둑판 하단 여백 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/board_margin_bottom"
            android:background="@color/board_color" />

    </LinearLayout>

    <!-- 하단 컨트롤 영역 (weight=30) -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="30"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- 기보명 + 모드 정보 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:background="@color/bg_info_bar"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/btn_scan"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvSectionName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="기본도"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/tvModeInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기본도 입력 모드"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />

        </LinearLayout>

        <!-- 흑/백 전환 + 실행 취소 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical"
            android:background="@color/bg_action_bar">

            <TextView
                android:id="@+id/tvNextColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="다음: 흑 ●"
                android:textSize="13sp"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btnToggleColor"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height"
                android:layout_marginEnd="6dp"
                android:text="흑→백"
                android:textSize="@dimen/btn_text_size"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/btn_neutral"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:elevation="4dp"
                style="?attr/materialButtonStyle" />

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/btn_height"
                android:text="↩ 취소"
                android:textSize="@dimen/btn_text_size"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/btn_undo"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:elevation="4dp"
                style="?attr/materialButtonStyle" />

        </LinearLayout>

        <!-- 모드 전환 + 기보 추가 + 기보 삭제 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#FFFFFF"
            android:elevation="1dp">

            <Button
                android:id="@+id/btnToggleMode"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_weight="2"
                android:layout_marginEnd="4dp"
                android:text="착수 입력으로 전환"
                android:textSize="@dimen/btn_text_size"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/btn_toggle_mode"
                android:elevation="4dp"
                style="?attr/materialButtonStyle" />

            <Button
                android:id="@+id/btnAddSection"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="+ 기보"
                android:textSize="@dimen/btn_text_size"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/btn_add"
                android:elevation="4dp"
                style="?attr/materialButtonStyle" />

            <Button
                android:id="@+id/btnDelSection"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="삭제"
                android:textSize="@dimen/btn_text_size"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/btn_del"
                android:elevation="4dp"
                style="?attr/materialButtonStyle" />

        </LinearLayout>

        <!-- 마커 도구 팔레트 (착수 입력 모드에서만 표시) -->
        <HorizontalScrollView
            android:id="@+id/markerToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
            android:background="@color/bg_action_bar"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="마커:"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnToolMove"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="3dp"
                    android:text="착수"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

                <Button
                    android:id="@+id/btnToolTriangle"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="3dp"
                    android:text="△"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_neutral"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

                <Button
                    android:id="@+id/btnToolCircle"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="3dp"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_neutral"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

                <Button
                    android:id="@+id/btnToolSquare"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="3dp"
                    android:text="□"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_neutral"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

                <Button
                    android:id="@+id/btnToolX"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="3dp"
                    android:text="✕"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_neutral"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

                <Button
                    android:id="@+id/btnToolLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="3dp"
                    android:text="A"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_neutral"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

                <Button
                    android:id="@+id/btnToolEraseMarker"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="지우기"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_del"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    style="?attr/materialButtonStyle" />

            </LinearLayout>
        </HorizontalScrollView>


        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- 시크바 -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <!-- 네비게이션 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@color/bg_nav_bar"
            android:elevation="1dp">

            <ImageButton
                android:id="@+id/btnFirst"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="처음" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_rew"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="이전" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="다음" />

            <ImageButton
                android:id="@+id/btnLast"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="끝" />

        </LinearLayout>

        <!-- 기보 목록 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:background="@color/bg_section_header"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/primary"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="기보 목록"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 기보 목록 ListView -->
        <ListView
            android:id="@+id/lvSections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="@dimen/section_list_min_height"
            android:divider="@color/divider"
            android:dividerHeight="1dp"
            android:background="#FFFFFF" />

    </LinearLayout>

    <!-- 하단 네비게이션 바 스페이서 -->
    <View
        android:id="@+id/navBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:background="@color/board_color" />

</LinearLayout>
