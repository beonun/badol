<?xml version="1.0" encoding="utf-8"?>
<!--
    Landscape Editor 레이아웃 (태블릿 sw >= 600dp, 가로 모드)
    구조: AppBar / [바둑판(좌) + 컨트롤패널(우, ScrollView)]
    - controlPanel 전체를 ScrollView로 감싸 마커 팔레트 등 모든 요소 스크롤 접근 가능
    - 바둑판 우하단에 전체화면 토글 버튼 오버레이
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/board_color">

    <!-- 툴바 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/btn_scan"
            app:titleTextColor="#FFFFFF"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 가로 모드: 바둑판 좌측 + 컨트롤 패널 우측 -->
    <RelativeLayout
        android:id="@+id/contentRow"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 오른쪽 컨트롤 패널 (ScrollView로 감싸서 세로 스크롤 가능) -->
        <ScrollView
            android:id="@+id/controlPanelScroll"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:background="#FFFFFF"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/bottomPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF">

                <!-- ── 정보 표시 바: 기보명 + 모드 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/bg_info_bar"
                    android:paddingStart="0dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/btn_scan"
                        android:layout_marginEnd="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSectionName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="기본도"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                        <TextView
                            android:id="@+id/tvModeInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="기본도 입력 모드"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── 액션 버튼 행: 다음 착수색 + 흑/백 전환 + 실행 취소 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:gravity="center_vertical"
                    android:background="@color/bg_action_bar">

                    <TextView
                        android:id="@+id/tvNextColor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="다음: 흑 ●"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <Button
                        android:id="@+id/btnToggleColor"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginEnd="4dp"
                        android:text="흑→백"
                        android:textSize="@dimen/btn_text_size"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/btn_neutral"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:elevation="4dp"
                        style="?attr/materialButtonStyle" />

                    <Button
                        android:id="@+id/btnUndo"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/btn_height"
                        android:text="↩ 취소"
                        android:textSize="@dimen/btn_text_size"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/btn_undo"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:elevation="4dp"
                        style="?attr/materialButtonStyle" />

                </LinearLayout>

                <!-- ── 모드 전환 버튼 ── -->
                <Button
                    android:id="@+id/btnToggleMode"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginTop="5dp"
                    android:text="착수 입력으로 전환"
                    android:textSize="@dimen/btn_text_size"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/btn_toggle_mode"
                    android:elevation="4dp"
                    style="?attr/materialButtonStyle" />

                <!-- ── 기보 추가 / 기보 삭제 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <Button
                        android:id="@+id/btnAddSection"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/btn_height"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="+ 기보 추가"
                        android:textSize="@dimen/btn_text_size"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/btn_add"
                        android:elevation="4dp"
                        style="?attr/materialButtonStyle" />

                    <Button
                        android:id="@+id/btnDelSection"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/btn_height"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="기보 삭제"
                        android:textSize="@dimen/btn_text_size"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="@color/btn_del"
                        android:elevation="4dp"
                        style="?attr/materialButtonStyle" />

                </LinearLayout>

                <!-- ── 마커 도구 팔레트 ── -->
                <HorizontalScrollView
                    android:id="@+id/markerToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
            android:background="#996B7C3A"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:gravity="center_vertical">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToolTriangle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:layout_marginEnd="4dp"
                    android:text="△"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#AAFFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToolCircle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:layout_marginEnd="4dp"
                    android:text="○"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#AAFFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToolSquare"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:layout_marginEnd="4dp"
                    android:text="□"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#AAFFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToolX"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:layout_marginEnd="4dp"
                    android:text="✕"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#AAFFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToolLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:layout_marginEnd="8dp"
                    android:text="A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="#AAFFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToolEraseMarker"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minHeight="40dp"
                    android:minWidth="0dp"
                    android:text="지우기"
                    android:textSize="13sp"
                    android:textColor="@color/btn_del"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="@color/btn_del_light"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:gravity="center" />
            </LinearLayout>
        </HorizontalScrollView>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- ── 시크바 ── -->
                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp" />

                <!-- ── 네비게이션 버튼 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@color/bg_nav_bar"
                    android:elevation="1dp">

                    <ImageButton
                        android:id="@+id/btnFirst"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_media_previous"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="처음" />

                    <ImageButton
                        android:id="@+id/btnPrev"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_media_rew"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="이전" />

                    <ImageButton
                        android:id="@+id/btnNext"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_media_ff"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="다음" />

                    <ImageButton
                        android:id="@+id/btnLast"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_media_next"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="끝" />

                </LinearLayout>

                <!-- ── 기보 목록 헤더 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="26dp"
                    android:orientation="horizontal"
                    android:background="@color/bg_section_header"
                    android:paddingEnd="10dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="기보 목록"
                        android:textSize="11sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 기보 목록 -->
                <ListView
                    android:id="@+id/lvSections"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/section_list_min_height"
                    android:divider="@color/divider"
                    android:dividerHeight="1dp"
                    android:background="#FFFFFF" />

            </LinearLayout>

        </ScrollView>

        <!-- 바둑판 (좌측) -->
        <FrameLayout
            android:id="@+id/boardContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_toStartOf="@id/controlPanelScroll"
            android:layout_alignParentStart="true"
            android:background="@color/board_color">

            <com.badol.studio.BoardView
                android:id="@+id/boardView"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <!-- 전체화면 토글 버튼 (우하단 오버레이) -->
            <ImageButton
                android:id="@+id/btnFullscreen"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:src="@android:drawable/ic_menu_zoom"
                android:background="#88000000"
                android:tint="#FFFFFF"
                android:contentDescription="전체화면"
                android:padding="6dp" />

        </FrameLayout>

    </RelativeLayout>

</LinearLayout>
